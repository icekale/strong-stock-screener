# The production static server proxies same-origin API calls to FastAPI.
VITE_API_BASE_URL=

VITE_HTTP_PROXY=N

VITE_ROUTER_HISTORY_MODE=history

VITE_ROUTE_HOME=root

VITE_BASE_URL=/

VITE_APP_TITLE=StockMaster

