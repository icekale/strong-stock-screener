<?xml version="1.0" encoding="utf-8"?>
<Container version="2">
  <Name>StockMaster</Name>
  <Repository>icekale/strong-stock-screener:latest</Repository>
  <Registry>https://hub.docker.com/r/icekale/strong-stock-screener</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/icekale/strong-stock-screener/issues</Support>
  <Project>https://github.com/icekale/strong-stock-screener</Project>
  <Overview>StockMaster 是一个私有化 A 股强势股工作台，包含强势股筛选、竞价雷达、竞价 Top3 模型试运行、板块资金流、短线情绪、自选股观察池和个股 K 线复盘。仅作研究辅助，不做自动交易。</Overview>
  <Category>Productivity: Tools:</Category>
  <WebUI>http://[IP]:[PORT:3110]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/icekale/strong-stock-screener/main/unraid/strong-stock-screener.xml</TemplateURL>
  <Icon/>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Web UI Port" Target="3110" Default="3110" Mode="tcp" Description="StockMaster Web 访问端口" Type="Port" Display="always" Required="true" Mask="false">3110</Config>
  <Config Name="AppData" Target="/app/data" Default="/mnt/user/appdata/strong-stock-screener" Mode="rw" Description="运行时配置、自选股、筛选记录、竞价模型缓存和复盘数据" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/strong-stock-screener</Config>
  <Config Name="Timezone" Target="TZ" Default="Asia/Shanghai" Mode="" Description="容器时区" Type="Variable" Display="always" Required="true" Mask="false">Asia/Shanghai</Config>
  <Config Name="Data Directory" Target="STRONG_STOCK_DATA_DIR" Default="/app/data" Mode="" Description="容器内持久化数据目录" Type="Variable" Display="advanced" Required="true" Mask="false">/app/data</Config>
  <Config Name="TickFlow API Key" Target="STRONG_STOCK_TICKFLOW_API_KEY" Default="" Mode="" Description="TickFlow 行情和 K 线 API Key，建议填写" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="TickFlow Base URL" Target="STRONG_STOCK_TICKFLOW_BASE_URL" Default="https://api.tickflow.org" Mode="" Description="TickFlow API 地址" Type="Variable" Display="advanced" Required="false" Mask="false">https://api.tickflow.org</Config>
  <Config Name="iFinD API Key" Target="STRONG_STOCK_IFIND_API_KEY" Default="" Mode="" Description="iFinD MCP API Key，可选，用于公告、新闻、财务、估值和风险事件增强" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="iFinD Base URL" Target="STRONG_STOCK_IFIND_BASE_URL" Default="https://api-mcp.51ifind.com:8643" Mode="" Description="iFinD MCP 地址" Type="Variable" Display="advanced" Required="false" Mask="false">https://api-mcp.51ifind.com:8643</Config>
  <Config Name="iFinD Service ID" Target="STRONG_STOCK_IFIND_SERVICE_ID" Default="hexin-ifind-ds-stock-mcp" Mode="" Description="iFinD MCP Service ID" Type="Variable" Display="advanced" Required="false" Mask="false">hexin-ifind-ds-stock-mcp</Config>
  <Config Name="free-stockdb URL" Target="STRONG_STOCK_AUCTION_MODEL_FREE_STOCKDB_BASE_URL" Default="" Mode="" Description="free-stockdb 服务地址。只在重新生成竞价 Top3 模型结果时需要，例如 http://192.168.5.221:7899" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="CORS Origins" Target="STRONG_STOCK_CORS_ALLOW_ORIGINS" Default="http://localhost:3110,http://127.0.0.1:3110" Mode="" Description="允许访问 API 的前端地址" Type="Variable" Display="advanced" Required="false" Mask="false">http://localhost:3110,http://127.0.0.1:3110</Config>
  <Config Name="Screen Run Retention" Target="STRONG_STOCK_SCREEN_RUN_RETENTION_COUNT" Default="120" Mode="" Description="筛选记录保留数量" Type="Variable" Display="advanced" Required="false" Mask="false">120</Config>
  <Config Name="Auction Review Retention Days" Target="STRONG_STOCK_AUCTION_REVIEW_RETENTION_DAYS" Default="120" Mode="" Description="竞价复盘保留天数" Type="Variable" Display="advanced" Required="false" Mask="false">120</Config>
</Container>
